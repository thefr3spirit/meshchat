<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBackground">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/peersHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/headerBackground"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_peers"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/peers_subtitle"
            android:textSize="13sp"
            android:textColor="#B2DFDB"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/emptyPeersState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_peers_connected"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/peersHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Peers list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPeers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/peersHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
