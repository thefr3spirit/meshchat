<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBackground">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatsHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/headerBackground"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MESHCHAT"
            android:textSize="11sp"
            android:textColor="#80FFFFFF"
            android:textAllCaps="true"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_chats"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:letterSpacing="-0.01"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Conversations list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerConversations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/chatsHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
