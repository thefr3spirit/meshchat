<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Avatar with online status dot -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp">

            <View
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/avatar_circle"
                android:backgroundTint="@color/colorPrimary" />

            <TextView
                android:id="@+id/nodeAvatarText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <!-- Online indicator dot in bottom-right corner -->
            <View
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:background="@drawable/status_dot"
                android:backgroundTint="@color/statusOnline"
                android:layout_gravity="bottom|end"
                android:layout_margin="1dp" />
        </FrameLayout>

        <!-- Name and signal strength -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/nodeUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary" />

            <!-- Signal bars + label row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <!-- Signal bars (gravity=bottom so bars grow upward) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginEnd="6dp">

                    <View android:id="@+id/signalBar1"
                        android:layout_width="4dp"
                        android:layout_height="5dp"
                        android:background="@drawable/signal_bar"
                        android:layout_marginEnd="2dp" />

                    <View android:id="@+id/signalBar2"
                        android:layout_width="4dp"
                        android:layout_height="9dp"
                        android:background="@drawable/signal_bar"
                        android:layout_marginEnd="2dp" />

                    <View android:id="@+id/signalBar3"
                        android:layout_width="4dp"
                        android:layout_height="13dp"
                        android:background="@drawable/signal_bar"
                        android:layout_marginEnd="2dp" />

                    <View android:id="@+id/signalBar4"
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@drawable/signal_bar" />
                </LinearLayout>

                <TextView
                    android:id="@+id/nodeSignalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Message button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/messageButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="@string/message"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="20dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
